# NEXUS AI - Environment Configuration Example
# Copy this file to .env.local and fill in your actual credentials.

# -----------------------------------------------------------------------------
# SUPABASE CONFIGURATION
# -----------------------------------------------------------------------------
# Obtain these from your Supabase Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# -----------------------------------------------------------------------------
# BACKEND CONFIGURATION (Optional)
# -----------------------------------------------------------------------------
# The frontend defaults to http://localhost:8000 for the Python FastAPI server.
# If you deploy the backend elsewhere, you may need to update the API constants 
# in the React components (e.g., Dashboard.jsx).
# NEXT_PUBLIC_API_URL=http://localhost:8000
